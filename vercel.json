{
    "routes": [
        {
            "src": "/(.*)",
            "dest": "api/index.py"
        }
    ],
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python",
            "config": {
                "installCommand": "pip install -e .",
                "maxLambdaSize": "50mb"
            }
        }
    ]
}